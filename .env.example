# Frontend publico (Vite)
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_ANON_KEY=
VITE_SITE_URL=https://suplementosgrizzly.com
# Si el checkout usa Edge Functions publicas para invitados, conviene cargar tambien la anon key JWT.

# Supabase CLI / proyecto
SUPABASE_PROJECT_REF=
SUPABASE_DB_PASSWORD=
SUPABASE_SERVICE_ROLE_KEY=
APP_URL=https://suplementosgrizzly.com
SUPABASE_ACCESS_TOKEN=

# Secrets server-side
# Copiar estas variables a `supabase/functions/.env.local`
# o cargarlas como secrets en Supabase para produccion.
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_WEBHOOK_SECRET=
RESEND_API_KEY=
RESEND_FROM_EMAIL=
